# ─── TrainMatch Environment Variables ────────────────────────────────────────
#
# Copy this file to .env.local and fill in your Supabase values.
# Get them from: https://supabase.com → your project → Settings → API
#
# Without these the app runs in demo mode (no persistence, no real auth).

VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
